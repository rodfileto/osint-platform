# --- Environment Variables Template ---
# Copy this file to .env and fill in the values

COMPOSE_PROJECT_NAME=osint_platform

# --- Database (Postgres) ---
POSTGRES_USER=osint_admin
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=osint_metadata
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_EXPOSE_PORT=5432
POSTGRES_DATA_HOST_PATH=/srv/osint/postgres/data
POSTGRES_FAST_SSD_HOST_PATH=/srv/osint/postgres/ssd_tablespace
POSTGRES_SHM_SIZE=17g
POSTGRES_SHARED_BUFFERS=16GB
POSTGRES_EFFECTIVE_CACHE_SIZE=48GB
POSTGRES_WORK_MEM=64MB
POSTGRES_MAINTENANCE_WORK_MEM=2GB
POSTGRES_RANDOM_PAGE_COST=1.1
POSTGRES_EFFECTIVE_IO_CONCURRENCY=200
POSTGRES_MAX_WORKER_PROCESSES=8
POSTGRES_MAX_PARALLEL_WORKERS=8
POSTGRES_MAX_PARALLEL_WORKERS_PER_GATHER=4
POSTGRES_WAL_BUFFERS=64MB
POSTGRES_MIN_WAL_SIZE=1GB
POSTGRES_MAX_WAL_SIZE=4GB
POSTGRES_CHECKPOINT_COMPLETION_TARGET=0.9
POSTGRES_DEFAULT_STATISTICS_TARGET=200
POSTGRES_HUGE_PAGES=try

# --- Graph Database (Neo4j) ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_graph_password_here
NEO4J_URI=bolt://neo4j:7687
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_DATA_HOST_PATH=/srv/osint/neo4j/data
NEO4J_PAGECACHE_SIZE=6g
NEO4J_HEAP_SIZE=4g
NEO4J_TX_MEMORY=2g
NEO4J_TX_LOG_RETENTION_POLICY=2 files
NEO4J_CHECKPOINT_INTERVAL_TX=50

# --- Cache & Message Broker (Redis) ---
REDIS_HOST=redis
REDIS_PORT=6379  # Internal container port (exposed as 6380 on host)
REDIS_EXPOSE_PORT=6380
REDIS_DATA_HOST_PATH=./infrastructure/redis/data

# --- Object Storage (MinIO) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_this_minio_password
MINIO_DATA_HOST_PATH=/mnt/data10tb/osint/minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT_URL=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_this_minio_password
MINIO_REGION=us-east-1
MINIO_STORAGE_ENABLED=true
MINIO_STORAGE_BUCKET_MEDIA=osint-media
MINIO_STORAGE_BUCKET_EXPORTS=osint-exports
MINIO_MEDIA_LOCATION=media
MINIO_EXPORTS_LOCATION=exports

# --- Django App Runtime ---
DJANGO_SECRET_KEY=replace_with_a_unique_secret_key
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000
DJANGO_STATIC_URL=/static/
DJANGO_STATIC_ROOT=staticfiles
DJANGO_MEDIA_URL=/media/
DJANGO_MEDIA_ROOT=media
DJANGO_EXPORTS_URL=/exports/
DJANGO_EXPORTS_ROOT=exports
CNPJ_EXPORT_MAX_ROWS=5000
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120
BACKEND_PORT=8000

# --- Frontend App Runtime ---
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_PORT=3000

# --- Shared Geo Loader ---
GEOBR_YEAR=2019
GEOBR_SIMPLIFIED=true

# --- Airflow ---
AIRFLOW_UID=50000
AIRFLOW_GID=0
AIRFLOW_IMAGE_NAME=apache/airflow:2.10.4
AIRFLOW_DATA_HOST_PATH=/mnt/data10tb/osint/pipelines/data
AIRFLOW_TEMP_SSD_HOST_PATH=/srv/osint/airflow/temp_ssd
AIRFLOW_PORT=8080
# Generate a new Fernet key using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your_generated_fernet_key_here
AIRFLOW_WebSERVER_SECRET_KEY=your_secret_key_here
TZ=America/Sao_Paulo

# --- Cloudflare Tunnel (compose.tunnel.yml) ---
# Obtain from: Zero Trust dashboard → Networks → Tunnels → your tunnel → Configure → Token
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here
# Public hostnames configured in the tunnel ingress / DNS
CF_APP_DOMAIN=app.yourdomain.com
CF_API_DOMAIN=api.yourdomain.com
CF_AIRFLOW_DOMAIN=airflow.yourdomain.com
# Required when frontend is served via HTTPS through the tunnel
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
DJANGO_ALLOWED_HOSTS=api.yourdomain.com,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://app.yourdomain.com,https://api.yourdomain.com
