# --- Environment Variables Template ---
# Copy this file to .env and fill in the values

# --- Database (Postgres) ---
POSTGRES_USER=osint_admin
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=osint_metadata
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATA_HOST_PATH=/srv/osint/postgres/data
POSTGRES_FAST_SSD_HOST_PATH=/srv/osint/postgres/ssd_tablespace

# --- Graph Database (Neo4j) ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_graph_password_here
NEO4J_URI=bolt://neo4j:7687
NEO4J_DATA_HOST_PATH=/srv/osint/neo4j/data

# --- Cache & Message Broker (Redis) ---
REDIS_HOST=redis
REDIS_PORT=6379  # Internal container port (exposed as 6380 on host)

# --- Object Storage (MinIO) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_this_minio_password
MINIO_DATA_HOST_PATH=/mnt/data10tb/osint/minio
MINIO_ENDPOINT_URL=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_this_minio_password
MINIO_REGION=us-east-1
MINIO_STORAGE_ENABLED=true
MINIO_STORAGE_BUCKET_MEDIA=osint-media
MINIO_STORAGE_BUCKET_EXPORTS=osint-exports
MINIO_MEDIA_LOCATION=media
MINIO_EXPORTS_LOCATION=exports

# --- Django App Runtime ---
DJANGO_SECRET_KEY=replace_with_a_unique_secret_key
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000
DJANGO_STATIC_URL=/static/
DJANGO_STATIC_ROOT=staticfiles
DJANGO_MEDIA_URL=/media/
DJANGO_MEDIA_ROOT=media
DJANGO_EXPORTS_URL=/exports/
DJANGO_EXPORTS_ROOT=exports
CNPJ_EXPORT_MAX_ROWS=5000
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120

# --- Frontend App Runtime ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Shared Geo Loader ---
GEOBR_YEAR=2019
GEOBR_SIMPLIFIED=true

# --- Airflow ---
AIRFLOW_UID=50000
AIRFLOW_GID=0
AIRFLOW_IMAGE_NAME=apache/airflow:2.10.4
AIRFLOW_DATA_HOST_PATH=/mnt/data10tb/osint/pipelines/data
AIRFLOW_TEMP_SSD_HOST_PATH=/srv/osint/airflow/temp_ssd
# Generate a new Fernet key using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your_generated_fernet_key_here
AIRFLOW_WebSERVER_SECRET_KEY=your_secret_key_here
